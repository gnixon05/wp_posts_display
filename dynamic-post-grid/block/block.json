{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "dpg/post-grid",
	"version": "1.1.0",
	"title": "Dynamic Post Grid",
	"category": "widgets",
	"icon": "grid-view",
	"description": "Configurable post grid with multiple card styles and an optional AJAX filter bar.",
	"keywords": [ "grid", "posts", "filter", "salient", "magazine" ],
	"textdomain": "dynamic-post-grid",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"editorScript": "dpg-block",
	"editorStyle": "dpg-block-editor",
	"attributes": {
		"post_type":        { "type": "string",  "default": "post" },
		"posts_per_page":   { "type": "number",  "default": 9 },
		"offset":           { "type": "number",  "default": 0 },
		"order":            { "type": "string",  "default": "DESC" },
		"orderby":          { "type": "string",  "default": "date" },
		"meta_key":         { "type": "string",  "default": "" },
		"include_terms":    { "type": "string",  "default": "" },
		"exclude_terms":    { "type": "string",  "default": "" },
		"include_ids":      { "type": "string",  "default": "" },
		"exclude_ids":      { "type": "string",  "default": "" },
		"exclude_current":  { "type": "boolean", "default": false },
		"sticky":           { "type": "string",  "default": "default" },
		"meta_query":       { "type": "string",  "default": "" },

		"style":            { "type": "string",  "default": "classic" },
		"columns":          { "type": "number",  "default": 3 },
		"columns_tablet":   { "type": "number",  "default": 2 },
		"columns_mobile":   { "type": "number",  "default": 1 },
		"gap":              { "type": "number",  "default": 30 },
		"mode":             { "type": "string",  "default": "grid" },

		"show_image":       { "type": "boolean", "default": true },
		"image_size":       { "type": "string",  "default": "large" },
		"fallback_image":   { "type": "string",  "default": "" },
		"show_title":       { "type": "boolean", "default": true },
		"show_excerpt":     { "type": "boolean", "default": true },
		"excerpt_length":   { "type": "number",  "default": 22 },
		"show_date":        { "type": "boolean", "default": true },
		"show_author":      { "type": "boolean", "default": false },
		"show_avatar":      { "type": "boolean", "default": false },
		"show_category":    { "type": "boolean", "default": true },
		"show_readmore":    { "type": "boolean", "default": false },
		"readmore_text":    { "type": "string",  "default": "" },
		"hover":            { "type": "string",  "default": "zoom" },

		"pagination":       { "type": "string",  "default": "none" },
		"loadmore_text":    { "type": "string",  "default": "" },

		"filter_enable":       { "type": "boolean", "default": false },
		"filter_taxonomies":   { "type": "string",  "default": "" },
		"filter_labels":       { "type": "string",  "default": "" },
		"filter_search":       { "type": "boolean", "default": true },
		"filter_terms_scope":  { "type": "string",  "default": "used" },
		"filter_apply":        { "type": "string",  "default": "live" },
		"filter_search_label": { "type": "string",  "default": "" }
	}
}
